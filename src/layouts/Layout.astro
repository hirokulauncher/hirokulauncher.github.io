---
import favicon from '../assets/favicon.svg';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Hiroku Launcher — Your Worlds, One Tap Away', description = 'Hiroku Launcher — a beautiful, glass-themed Minecraft launcher for Android with video backgrounds, mod support, and cinematic UI.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content="Hiroku Launcher" />
    <meta property="og:description" content="Your Worlds, One Tap Away. A stunning Minecraft launcher for Android." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <is:inline>
      <script>
        (function(){try{var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}}catch(e){}})();
      </script>
    </is:inline>
  </head>
  <body class="bg-hiroku-dark text-white overflow-x-hidden">
    <slot />
  </body>
</html>
