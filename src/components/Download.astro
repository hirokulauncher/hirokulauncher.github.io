<section id="download" class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 hero-bg"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-hiroku-dark via-transparent to-hiroku-dark"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-hiroku-primary/5 blur-3xl animate-pulse-ring"></div>

  <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
    <span class="text-hiroku-primary text-sm font-semibold tracking-widest uppercase">Download</span>
    <h2 class="text-4xl md:text-6xl font-bold mt-3 mb-4">Get Hiroku</h2>
    <p class="text-hiroku-accent/60 text-lg mb-12 max-w-xl mx-auto">Free and open source. No ads, no tracking. Just your worlds, one tap away.</p>

    <div class="glass-strong rounded-3xl p-8 md:p-12 max-w-lg mx-auto">
      <div class="mb-6">
        <span class="text-3xl font-black text-hiroku-primary">v2.4.3</span>
        <span class="text-hiroku-accent/40 text-sm ml-2">Latest</span>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-8 text-left">
        <div class="glass rounded-xl p-4">
          <span class="text-hiroku-accent/40 text-xs uppercase tracking-wider">Min Android</span>
          <span class="text-lg font-bold block mt-1">8.0+</span>
        </div>
        <div class="glass rounded-xl p-4">
          <span class="text-hiroku-accent/40 text-xs uppercase tracking-wider">Size</span>
          <span class="text-lg font-bold block mt-1">~255 MB</span>
        </div>
        <div class="glass rounded-xl p-4">
          <span class="text-hiroku-accent/40 text-xs uppercase tracking-wider">Package</span>
          <span class="text-sm font-bold block mt-1 text-hiroku-accent/70 break-all">com.hiroku.launcher</span>
        </div>
        <div class="glass rounded-xl p-4">
          <span class="text-hiroku-accent/40 text-xs uppercase tracking-wider">License</span>
          <span class="text-lg font-bold block mt-1">GPL-3.0</span>
        </div>
      </div>

      <a href="https://github.com/hirokulauncher/hirokulauncher.github.io/releases/download/v2.4.3/HirokuLauncher-2.4.3-arm64-v8a.apk" class="download-btn w-full py-4 rounded-2xl text-lg font-bold text-hiroku-dark flex items-center justify-center gap-3">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"></path></svg>
        Download APK (arm64)
      </a>

      <a href="https://github.com/hirokulauncher/hirokulauncher.github.io/releases/download/v2.4.3/HirokuLauncher-2.4.3.apk" class="glass mt-3 w-full py-3 rounded-xl text-sm font-medium text-hiroku-accent/60 flex items-center justify-center gap-2 hover:text-hiroku-accent/80 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"></path></svg>
        Universal APK (all devices, ~337 MB)
      </a>

      <p class="text-hiroku-accent/30 text-xs mt-3">Allow installation from unknown sources in your device settings</p>
    </div>
  </div>
</section>
