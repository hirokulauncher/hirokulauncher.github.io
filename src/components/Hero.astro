---
import splashImg from '../assets/splashscreen.jpg';
---

<section class="hero-bg min-h-screen flex items-center relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-hiroku-dark/90"></div>

  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-hiroku-primary/5 blur-3xl animate-pulse-ring"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-hiroku-accent/5 blur-3xl animate-pulse-ring" style="animation-delay:1.5s"></div>

  <div class="max-w-7xl mx-auto px-6 pt-24 pb-20 relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <div class="animate-fade-up inline-flex items-center gap-2 glass-light rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 rounded-full bg-hiroku-green animate-pulse"></span>
        <span class="text-xs font-medium text-hiroku-accent">Now Available for Android</span>
      </div>

      <h1 class="animate-fade-up text-5xl md:text-7xl lg:text-8xl font-black tracking-tight leading-none mb-6" style="animation-delay:0.1s">
        <span class="text-white">Hiroku</span><br>
        <span class="text-hiroku-primary glow-text">Launcher</span>
      </h1>

      <p class="animate-fade-up text-xl md:text-2xl text-hiroku-accent font-light mb-4 tracking-wide" style="animation-delay:0.2s">
        Your Worlds, One Tap Away
      </p>
      <p class="animate-fade-up text-base text-hiroku-accent/60 max-w-2xl mx-auto mb-10" style="animation-delay:0.3s">
        A cinematic, glass-themed Minecraft launcher for Android. Video backgrounds, mod support,
        stunning UI — everything you need to dive into your world.
      </p>

      <div class="animate-fade-up flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" style="animation-delay:0.4s">
        <a href="#download" class="download-btn-disabled px-8 py-4 rounded-2xl text-lg font-bold text-hiroku-dark flex items-center gap-3 cursor-not-allowed" title="Coming soon">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"/></svg>
          Download APK
        </a>
        <a href="#features" class="glass px-8 py-4 rounded-2xl text-lg font-semibold text-white hover:border-hiroku-primary/40 transition-all duration-300 flex items-center gap-3">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          See Features
        </a>
      </div>

      <div class="animate-fade-up animate-float relative mx-auto w-64 md:w-80" style="animation-delay:0.5s">
        <div class="glass-strong rounded-3xl p-3 glow-primary">
          <div class="bg-hiroku-dark rounded-2xl overflow-hidden aspect-[9/19] relative">
            <img src={splashImg.src} alt="Hiroku Launcher Splash Screen" class="w-full h-full object-contain" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
